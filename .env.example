# =============================================================
# EduManage SA – Environment Variables
# Copy this file to .env at the repo root and fill in values.
# Both the backend server and all Prisma CLI commands load from
# this single file.
# =============================================================

# Database
DATABASE_URL="postgresql://edumanage:your_password@localhost:5432/edumanage_db?schema=public"

# Server
PORT=5000
NODE_ENV=development

# JWT (change these in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# CORS
FRONTEND_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Optional: Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional: SMS Gateway
SMS_API_KEY=your-sms-api-key
SMS_API_URL=https://api.smsprovider.co.za/send
